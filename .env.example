# BALISA — Environment Variables
# Copia questo file in .env.local e sostituisci i valori.

# SUPABASE
# Supabase Dashboard -> Project Settings -> API
NEXT_PUBLIC_SUPABASE_URL=https://TUO-PROGETTO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=INSERISCI_ANON_PUBLIC_KEY
SUPABASE_SERVICE_ROLE_KEY=INSERISCI_SERVICE_ROLE_KEY

# STRIPE
# Stripe Dashboard -> Developers -> API keys
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_SECRET_KEY=sk_live_...
# Stripe Dashboard -> Developers -> Webhooks -> Signing secret
STRIPE_WEBHOOK_SECRET=whsec_...

# APP
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ADMIN
# Questa è la password/chiave che userai su /admin
ADMIN_SECRET_KEY=cambia_questa_chiave
