# ============================================================
# BALISA — Environment Variables
# Copia questo file in .env.local e riempilo con i tuoi valori
# ============================================================

# ── SUPABASE ─────────────────────────────────────────────────
# Prendi da: https://supabase.com → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── STRIPE ───────────────────────────────────────────────────
# Prendi da: https://dashboard.stripe.com → Developers → API Keys
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_SECRET_KEY=sk_live_...
# Prendi da: https://dashboard.stripe.com → Webhooks → Signing secret
STRIPE_WEBHOOK_SECRET=whsec_...

# ── APP ──────────────────────────────────────────────────────
# URL del tuo sito (senza slash finale)
NEXT_PUBLIC_SITE_URL=https://yourbalisa.com

# Chiave segreta per accedere al pannello admin
# Scegli una stringa lunga e casuale, es: openssl rand -hex 32
ADMIN_SECRET_KEY=cambia_questa_chiave_con_qualcosa_di_sicuro
